# Copy this file to ".env" and fill in your values. Do NOT commit .env.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Passcode for the /admin dashboard. Set a strong value before launch.
# NOTE: because this is a frontend app, this code is still visible to anyone who
# inspects the shipped JavaScript. It deters casual access only — see LAUNCH_CHECKLIST.md
# for the proper fix (Supabase Auth).
VITE_ADMIN_CODE=change-me-before-launch
